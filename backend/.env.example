# ── Core ──────────────────────────────────────────────
NODE_ENV=production
PORT=3000
MONGO_URI=mongodb+srv://USER:PASS@cluster.mongodb.net/acta
JWT_SECRET=replace-me-with-a-long-random-string
SESSION_SECRET=replace-me-with-another-long-random-string
BOT_ENCRYPTION_KEY=replace-with-32-byte-hex

# ── Google OAuth ──────────────────────────────────────
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=https://your-backend.example.com/api/auth/google/callback

# ── AI / Transcription providers ──────────────────────
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GROQ_API_KEY=
DEEPGRAM_API_KEY=
ASSEMBLYAI_API_KEY=

# ── Azure / Translation (optional) ────────────────────
AZURE_TEXT_ANALYTICS_KEY=
AZURE_TEXT_ANALYTICS_ENDPOINT=
GOOGLE_TRANSLATE_API_KEY=
ENABLE_TRANSLATION=false

# ── Zoom (optional) ───────────────────────────────────
ZOOM_ACCOUNT_ID=
ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

# ── Notifications (optional) ──────────────────────────
EMAIL_USER=
EMAIL_PASS=
EMAIL_PASSWORD=
ALERT_EMAIL=
SLACK_BOT_TOKEN=
TEAMS_WEBHOOK_URL=
WEBHOOK_URL=

# ── Python transcription (optional — only if you ship the Python stack) ──
# PYTHON_EXECUTABLE=/usr/bin/python3
