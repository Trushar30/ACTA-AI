{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "framework": "vite",
  "buildCommand": "vite build",
  "outputDirectory": "dist",
  "rewrites": [
    { "source": "/api/:path*", "destination": "http://45.77.168.91:3001/api/:path*" },
    { "source": "/socket.io/:path*", "destination": "http://45.77.168.91:3001/socket.io/:path*" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
